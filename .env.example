# Database (matches docker-compose.yml)
DATABASE_URL="postgresql://videoscroll:videoscroll@localhost:5432/videoscroll"

# Job queue (Phase 2 — worker)
REDIS_URL="redis://localhost:6379"

# AI — script generation (optional for demo mode)
OPENAI_API_KEY=""

# Stock video clips (free — https://www.pexels.com/api/)
PEXELS_API_KEY=""

# Optional video fallback if Pexels has no match (free — https://pixabay.com/api/docs/)
PIXABAY_API_KEY=""

# Rendered video output folder
OUTPUT_DIR="./output"

# Optional royalty-free MP3 URL mixed under voiceover at low volume
# BACKGROUND_MUSIC_URL="https://example.com/ambient.mp3"

# OAuth — YouTube & Instagram (Phase 1 stubs, wire up later)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
META_APP_ID=""
META_APP_SECRET=""
