# Database (matches docker-compose.yml)
DATABASE_URL="postgresql://videoscroll:videoscroll@localhost:5432/videoscroll"

# Job queue — run `npm run worker` in a second terminal for background renders
REDIS_URL="redis://localhost:6379"

# App URL for OAuth callbacks
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Encrypt OAuth tokens at rest (change in production)
TOKEN_ENCRYPTION_KEY="change-me-to-a-long-random-string"

# AI — script generation (optional for demo mode)
OPENAI_API_KEY=""

# Stock video clips (free — https://www.pexels.com/api/)
PEXELS_API_KEY=""

# Optional video fallback if Pexels has no match (free — https://pixabay.com/api/docs/)
PIXABAY_API_KEY=""

# Rendered video output folder
OUTPUT_DIR="./output"

# Optional royalty-free MP3 URL mixed under voiceover at low volume
# BACKGROUND_MUSIC_URL="https://example.com/ambient.mp3"

# YouTube OAuth — https://console.cloud.google.com/
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Instagram / Meta OAuth — https://developers.facebook.com/
META_APP_ID=""
META_APP_SECRET=""

# Public base URL for rendered MP4s (required for Instagram Reels upload)
# e.g. ngrok tunnel or S3/CloudFront URL
# PUBLIC_VIDEO_BASE_URL="https://your-public-host/output"
